{
  "manifest_version": 3,
  "name": "Nigiriidesalmon Twitch VAFT",
  "version": "0.2.0",
  "description": "Nigiriidesalmon's local Twitch player cleanup fork based on the archived pixeltris/twitchadsolutions VAFT script.",
  "minimum_chrome_version": "102",
  "permissions": [
    "declarativeNetRequestWithHostAccess"
  ],
  "host_permissions": [
    "https://edge.ads.twitch.tv/*"
  ],
  "declarative_net_request": {
    "rule_resources": [
      {
        "id": "twitch_ads",
        "enabled": true,
        "path": "rules/twitch-ads.json"
      }
    ]
  },
  "content_scripts": [
    {
      "matches": [
        "https://www.twitch.tv/*"
      ],
      "js": [
        "vaft/vaft.user.js"
      ],
      "run_at": "document_start",
      "world": "MAIN"
    }
  ]
}
